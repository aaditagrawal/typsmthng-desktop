{
  "name": "typsmthng-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Folder-backed Typst editor for Electrobun",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build": "vite build && electrobun build",
    "build:canary": "vite build && electrobun build --env=canary",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.9.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.12",
    "@fontsource/geist-mono": "^5.2.7",
    "@myriaddreamin/typst-ts-renderer": "^0.7.0-rc2",
    "@myriaddreamin/typst-ts-web-compiler": "^0.7.0-rc2",
    "@myriaddreamin/typst.ts": "^0.7.0-rc2",
    "@replit/codemirror-vim": "^6.3.0",
    "@unified-latex/unified-latex-util-parse": "^1.8.3",
    "@unified-latex/unified-latex-util-visit": "^1.8.3",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "codemirror-lang-typst": "^0.4.0",
    "comlink": "^4.4.2",
    "electrobun": "1.15.1",
    "fflate": "^0.8.2",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.6.2",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@unified-latex/unified-latex-types": "^1.8.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.0.18"
  }
}
